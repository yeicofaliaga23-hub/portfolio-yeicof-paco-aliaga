{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the authenticated user and their analytics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." },
        "stats": {
          "type": "object",
          "properties": {
            "totalScans": { "type": "number" },
            "uniqueUsers": { "type": "number" },
            "lastScan": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "QRCodeConfig": {
      "title": "QR Code Configuration",
      "description": "The styling and data options for a QR code.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "options": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["options", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/history": {
      "schema": "QRCodeConfig",
      "description": "History of generated QR codes."
    },
    "/users/{userId}/favorites": {
      "schema": "QRCodeConfig",
      "description": "Favorite QR code configurations."
    }
  }
}
