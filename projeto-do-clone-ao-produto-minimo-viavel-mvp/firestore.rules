rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required) - Unique identifier
    //   - displayName: string (optional) - User's name
    //   - email: string (required) - User's email
    //   - photoURL: string (optional) - Profile picture URL
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "yeicofaliaga23@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 &&
             data.createdAt is timestamp &&
             (!('stats' in data) || (
               data.stats is map &&
               data.stats.totalScans is number &&
               data.stats.uniqueUsers is number
             ));
    }

    function isValidQRCode(data) {
      return data.keys().hasAll(['options', 'createdAt']) &&
             data.options is map &&
             data.createdAt is timestamp &&
             (!('name' in data) || (data.name is string && data.name.size() < 100)) &&
             (!('id' in data) || data.id is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own private data.
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.createdAt == resource.data.createdAt;
      
      allow delete: if isAdmin();

      match /history/{historyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidQRCode(request.resource.data);
        allow update: if isOwner(userId) && isValidQRCode(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /favorites/{favoriteId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidQRCode(request.resource.data);
        allow update: if isOwner(userId) && isValidQRCode(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
